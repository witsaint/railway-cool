# Legacy template — prefer `.env.local.example` for new local setup:
#   cp .env.local.example .env.local
# If you already use `.env`, it still works; `.env.local` overrides when present.
#
# Database (local dev only — on Railway, reference Postgres DATABASE_URL in service Variables)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/railway_dev?schema=public"

# Better Auth (production: set both to https://<your-railway-domain>, no trailing slash)
BETTER_AUTH_SECRET="generate-a-random-32-char-secret"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# GitHub OAuth — use a LOCAL dev OAuth App (see .env.local.example for full setup).
# Production credentials belong in Railway Variables only, not here.
# Local app callback URL must be: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Worker
WORKER_POLL_INTERVAL_MS="5000"
