# Database (local dev only — on Railway, reference Postgres DATABASE_URL in service Variables)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/railway_dev?schema=public"

# Better Auth
BETTER_AUTH_SECRET="generate-a-random-32-char-secret"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Worker
WORKER_POLL_INTERVAL_MS="5000"
