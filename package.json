{
  "name": "railway-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @repo/db db:generate",
    "db:push": "pnpm --filter @repo/db db:push",
    "db:push:deploy": "pnpm --filter @repo/db db:push:deploy",
    "db:migrate": "pnpm --filter @repo/db db:migrate",
    "db:migrate:deploy": "pnpm --filter @repo/db db:migrate:deploy",
    "db:studio": "pnpm --filter @repo/db db:studio"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24"
  }
}
