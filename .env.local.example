# Local development only — copy to repo root as `.env.local` (gitignored).
# Production values belong in Railway service Variables, not in this file.
#
#   cp .env.local.example .env.local
#
# If you already have a root `.env`, you can migrate local values with:
#   cp .env .env.local
# then edit `.env.local` as needed. `.env.local` overrides `.env` when both exist.

# --- Database ---
# Local Docker Postgres (after `docker compose up -d`):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/railway_dev?schema=public"
# Or use your Railway Postgres proxy URL for local dev against remote DB.

# --- Better Auth (local URLs, no trailing slash) ---
BETTER_AUTH_SECRET="generate-a-random-32-char-secret"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# --- GitHub OAuth (local dev app — separate from production) ---
# Create a second OAuth App at https://github.com/settings/developers for local dev:
#   Homepage URL:              http://localhost:3000
#   Authorization callback URL: http://localhost:3000/api/auth/callback/github
# Use that app's Client ID / Secret here. Keep production credentials in Railway only.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Worker (optional) ---
WORKER_POLL_INTERVAL_MS="5000"
